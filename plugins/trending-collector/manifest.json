{
  "manifest_version": 3,
  "name": "GitHub Trending Collector",
  "version": "0.1.0",
  "description": "Collects the daily GitHub Trending list and sends snapshots to a local service.",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "storage",
    "offscreen",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "GitHub Trending"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/trending*"
      ],
      "js": [
        "trending-parser.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://github.com/*",
    "https://api.github.com/*"
  ]
}
